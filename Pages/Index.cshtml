@page
@model EntraSsoSample.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<h1>Signed in via App Service EasyAuth 🎉</h1>
<p>
    This app has <strong>no authentication code</strong>. App Service runs the Entra
    sign-in <em>in front of</em> it and forwards your identity as
    <code>X-MS-CLIENT-PRINCIPAL-*</code> headers, shown below.
</p>

@if (Model.HasPrincipal)
{
    <ul>
        <li><strong>Name:</strong> @Model.Name</li>
        <li><strong>Identity provider:</strong> @Model.Idp</li>
        <li><strong>Object ID:</strong> @Model.PrincipalId</li>
    </ul>

    <h2>Claims <small>(decoded from <code>X-MS-CLIENT-PRINCIPAL</code>)</small></h2>
    <table>
        <thead>
            <tr><th>Claim type</th><th>Value</th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Claims)
            {
                <tr><td><code>@c.Type</code></td><td>@c.Value</td></tr>
            }
        </tbody>
    </table>
}
else
{
    <p>
        <em>No EasyAuth headers found — you're running locally, without the platform
        auth layer. Deploy behind App Service EasyAuth (see the README) to see your
        identity populate here.</em>
    </p>
}
