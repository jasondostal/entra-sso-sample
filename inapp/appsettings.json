{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "REPLACE-WITH-DIRECTORY-TENANT-ID",
    "ClientId": "REPLACE-WITH-APPLICATION-CLIENT-ID",

    "//ClientSecret": "Do NOT put the secret here. Locally use user-secrets (see README); in Azure it's an app setting (AzureAd__ClientSecret) or a Key Vault reference.",

    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },

  "MicrosoftGraph": {
    "BaseUrl": "https://graph.microsoft.com/v1.0",
    "Scopes": ["User.Read"]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
